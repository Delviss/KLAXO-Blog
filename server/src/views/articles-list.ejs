<%- include('partials/head') %>
<div class="flex items-center justify-between mb-6">
  <h1 class="font-display text-3xl font-bold">Articles</h1>
  <a href="/admin/articles/new" class="inline-flex items-center gap-2 bg-primary hover:bg-orange-600 text-white font-display font-bold uppercase text-sm tracking-tight px-4 py-2.5 rounded-lg transition">
    <span class="material-symbols-outlined text-base">add</span> New article
  </a>
</div>

<div class="flex gap-2 mb-4 text-sm">
  <a href="/admin/articles" class="px-3 py-1.5 rounded-lg <%= filter==='all' ? 'bg-primary-dark text-white' : 'bg-white border border-zinc-200' %>">All</a>
  <a href="/admin/articles?status=published" class="px-3 py-1.5 rounded-lg <%= filter==='published' ? 'bg-primary-dark text-white' : 'bg-white border border-zinc-200' %>">Published</a>
  <a href="/admin/articles?status=draft" class="px-3 py-1.5 rounded-lg <%= filter==='draft' ? 'bg-primary-dark text-white' : 'bg-white border border-zinc-200' %>">Drafts</a>
</div>

<div class="bg-white border border-zinc-200 rounded-xl overflow-hidden">
<% if (articles.length === 0) { %>
  <p class="px-5 py-10 text-center text-zinc-500 text-sm">No articles here yet.</p>
<% } else { %>
  <table class="w-full text-sm" data-articles-table>
    <thead class="bg-surface-2 text-left text-xs uppercase tracking-wide text-zinc-500">
      <tr>
        <th class="px-5 py-3 font-semibold">Title</th>
        <th class="px-3 py-3 font-semibold hidden sm:table-cell">Category</th>
        <th class="px-3 py-3 font-semibold">Status</th>
        <th class="px-3 py-3 font-semibold hidden md:table-cell">Updated</th>
        <th class="px-5 py-3 font-semibold text-right">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-zinc-100">
    <% articles.forEach(function(a){ %>
      <tr data-article-id="<%= a.id %>" data-article-slug="<%= a.slug %>">
        <td class="px-5 py-3">
          <a href="/admin/articles/<%= a.id %>/edit" class="font-semibold text-zinc-900 hover:text-primary-dark"><%= a.title %></a>
          <% if (a.publish_state === 'publish_failed') { %>
            <span class="ml-2 text-[10px] font-bold uppercase px-1.5 py-0.5 rounded bg-red-100 text-red-700" title="<%= a.publish_error %>">publish failed</span>
          <% } else if (a.publish_state === 'publishing') { %>
            <span class="ml-2 text-[10px] font-bold uppercase px-1.5 py-0.5 rounded bg-blue-100 text-blue-700">publishing…</span>
          <% } %>
        </td>
        <td class="px-3 py-3 hidden sm:table-cell text-zinc-600"><%= a.category %></td>
        <td class="px-3 py-3">
          <span class="text-[11px] font-bold uppercase px-2 py-1 rounded <%= a.status === 'published' ? 'bg-green-100 text-green-700' : 'bg-zinc-100 text-zinc-600' %>"><%= a.status %></span>
        </td>
        <td class="px-3 py-3 hidden md:table-cell text-zinc-500 text-xs"><%= new Date(a.updated_at).toISOString().slice(0,10) %></td>
        <td class="px-5 py-3">
          <div class="flex items-center justify-end gap-1">
            <a href="/admin/articles/<%= a.id %>/edit" class="p-2 rounded-lg hover:bg-surface-2" title="Edit"><span class="material-symbols-outlined text-base text-zinc-600">edit</span></a>
            <% if (a.status === 'published') { %>
              <a href="<%= siteBaseUrl %>/<%= a.slug %>.html" target="_blank" rel="noopener" class="p-2 rounded-lg hover:bg-surface-2" title="View live"><span class="material-symbols-outlined text-base text-zinc-600">open_in_new</span></a>
              <button data-action="unpublish" class="p-2 rounded-lg hover:bg-surface-2" title="Unpublish"><span class="material-symbols-outlined text-base text-zinc-600">unpublished</span></button>
            <% } else { %>
              <button data-action="publish" class="p-2 rounded-lg hover:bg-surface-2" title="Publish"><span class="material-symbols-outlined text-base text-green-600">publish</span></button>
            <% } %>
            <button data-action="delete" class="p-2 rounded-lg hover:bg-red-50" title="Delete"><span class="material-symbols-outlined text-base text-red-500">delete</span></button>
          </div>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
<% } %>
</div>
<%- include('partials/foot') %>
