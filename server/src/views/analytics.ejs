<%- include('partials/head') %>
<%
  function pct(cur, prev){ if(!prev) return cur>0 ? 100 : 0; return Math.round(((cur-prev)/prev)*100); }
  function trendClass(d){ return d > 0 ? 'text-green-700' : (d < 0 ? 'text-red-600' : 'text-zinc-400'); }
  function trendIcon(d){ return d > 0 ? 'trending_up' : (d < 0 ? 'trending_down' : 'trending_flat'); }
  const ov = data.overview, prev = data.previous;
  const series = data.series;
  // Time-series SVG geometry
  const W = 720, H = 220, PADL = 8, PADR = 8, PADT = 12, PADB = 22;
  const maxV = Math.max(1, ...series.map(s => s.pageviews));
  const n = series.length;
  function x(i){ return n <= 1 ? PADL : PADL + (i/(n-1))*(W-PADL-PADR); }
  function y(v){ return PADT + (1 - v/maxV)*(H-PADT-PADB); }
  function linePath(key){ return series.map((s,i)=> (i===0?'M':'L') + x(i).toFixed(1) + ' ' + y(s[key]).toFixed(1)).join(' '); }
  const pvPath = linePath('pageviews');
  const areaPath = n>0 ? (pvPath + ' L ' + x(n-1).toFixed(1) + ' ' + (H-PADB) + ' L ' + x(0).toFixed(1) + ' ' + (H-PADB) + ' Z') : '';
  const visPath = linePath('visitors');
  function barList(rows, key, labelKey){
    const max = Math.max(1, ...rows.map(r=>r[key]));
    return rows.map(r => ({ label: r[labelKey], value: r[key], w: Math.max(2, Math.round((r[key]/max)*100)) }));
  }
%>
<style>
  .viz { --surface-1:#fcfcfb; --ink:#0b0b0b; --ink-2:#52514e; --muted:#898781; --grid:#e1e0d9; --axis:#c3c2b7;
         --pv:#2a78d6; --vis:#eb6834; --seq:#2a78d6; }
  .bar-track { background:#f1f0ea; border-radius:9999px; height:10px; overflow:hidden; }
  .bar-fill { height:100%; border-radius:9999px; background:var(--seq); }
</style>

<div class="viz">
  <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
    <div>
      <h1 class="font-display text-3xl font-bold">Analytics</h1>
      <p class="text-zinc-500 text-sm mt-1"><%= range.fromStr %> → <%= range.toStr %></p>
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <div class="flex bg-white border border-zinc-200 rounded-lg overflow-hidden text-sm" data-range>
        <% ['today','7d','30d','90d'].forEach(function(p){ %>
          <a href="/admin/analytics?range=<%= p %>" class="px-3 py-2 <%= range.preset===p ? 'bg-primary-dark text-white' : 'hover:bg-surface-2' %>"><%= p==='today'?'Today':p %></a>
        <% }) %>
      </div>
      <a href="/admin/analytics/export.csv?range=<%= range.preset %>&from=<%= range.fromStr %>&to=<%= range.toStr %>" class="inline-flex items-center gap-1.5 border border-zinc-300 bg-white hover:bg-surface-2 text-zinc-700 font-semibold text-sm px-3 py-2 rounded-lg"><span class="material-symbols-outlined text-base">download</span>CSV</a>
    </div>
  </div>

  <!-- KPI tiles -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <% [['Pageviews','pageviews'],['Unique visitors','visitors'],['Clicks','clicks'],['Sessions','sessions']].forEach(function(kpi){
         var d = pct(ov[kpi[1]]||0, prev[kpi[1]]||0); %>
    <div class="bg-white border border-zinc-200 rounded-xl p-5">
      <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500"><%= kpi[0] %></p>
      <p class="font-display text-3xl font-bold mt-1" style="font-variant-numeric:tabular-nums"><%= (ov[kpi[1]]||0).toLocaleString() %></p>
      <p class="text-xs mt-1 inline-flex items-center gap-0.5 <%= trendClass(d) %>"><span class="material-symbols-outlined text-sm"><%= trendIcon(d) %></span><%= Math.abs(d) %>% vs prev</p>
    </div>
    <% }) %>
  </div>

  <!-- Time series -->
  <div class="bg-white border border-zinc-200 rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-display font-bold">Traffic over time</h2>
      <div class="flex items-center gap-4 text-xs">
        <span class="inline-flex items-center gap-1.5"><span class="w-3 h-0.5 rounded" style="background:#2a78d6"></span>Pageviews</span>
        <span class="inline-flex items-center gap-1.5"><span class="w-3 h-0.5 rounded" style="background:#eb6834"></span>Visitors</span>
      </div>
    </div>
    <% if (n === 0) { %>
      <p class="text-center text-zinc-400 text-sm py-12">No data in this range yet.</p>
    <% } else { %>
    <svg viewBox="0 0 <%= W %> <%= H %>" class="w-full" role="img" aria-label="Pageviews and visitors over time" style="max-height:240px">
      <line x1="<%= PADL %>" y1="<%= H-PADB %>" x2="<%= W-PADR %>" y2="<%= H-PADB %>" stroke="#c3c2b7" stroke-width="1"/>
      <path d="<%= areaPath %>" fill="#2a78d6" fill-opacity="0.08"/>
      <path d="<%= pvPath %>" fill="none" stroke="#2a78d6" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
      <path d="<%= visPath %>" fill="none" stroke="#eb6834" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
      <% series.forEach(function(s,i){ if(n<=1 || i % Math.ceil(n/6) === 0 || i===n-1){ %>
        <text x="<%= x(i).toFixed(1) %>" y="<%= H-6 %>" font-size="10" fill="#898781" text-anchor="middle"><%= s.day.slice(5) %></text>
      <% } }) %>
    </svg>
    <% } %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Top articles -->
    <div class="bg-white border border-zinc-200 rounded-xl p-5">
      <h2 class="font-display font-bold mb-4">Top articles</h2>
      <% var ta = barList(data.top, 'pageviews', 'slug'); if(ta.length===0){ %><p class="text-zinc-400 text-sm">No pageviews yet.</p><% } %>
      <ul class="space-y-3">
      <% ta.forEach(function(r){ %>
        <li>
          <div class="flex justify-between text-sm mb-1"><span class="truncate mr-2 text-zinc-700"><%= r.label %></span><span class="font-semibold tabular-nums"><%= r.value.toLocaleString() %></span></div>
          <div class="bar-track"><div class="bar-fill" style="width:<%= r.w %>%"></div></div>
        </li>
      <% }) %>
      </ul>
    </div>

    <!-- Traffic sources -->
    <div class="bg-white border border-zinc-200 rounded-xl p-5">
      <h2 class="font-display font-bold mb-4">Traffic sources</h2>
      <% var ts = barList(data.sources, 'pageviews', 'source'); if(ts.length===0){ %><p class="text-zinc-400 text-sm">No data yet.</p><% } %>
      <ul class="space-y-3">
      <% ts.forEach(function(r){ %>
        <li>
          <div class="flex justify-between text-sm mb-1"><span class="truncate mr-2 text-zinc-700"><%= r.label %></span><span class="font-semibold tabular-nums"><%= r.value.toLocaleString() %></span></div>
          <div class="bar-track"><div class="bar-fill" style="width:<%= r.w %>%"></div></div>
        </li>
      <% }) %>
      </ul>
    </div>

    <!-- Clicks report -->
    <div class="bg-white border border-zinc-200 rounded-xl p-5">
      <h2 class="font-display font-bold mb-4">Top clicks (CTAs & outbound)</h2>
      <% var tc = barList(data.clicks, 'clicks', 'target'); if(tc.length===0){ %><p class="text-zinc-400 text-sm">No clicks tracked yet.</p><% } %>
      <ul class="space-y-3">
      <% tc.forEach(function(r){ %>
        <li>
          <div class="flex justify-between text-sm mb-1"><span class="truncate mr-2 text-zinc-700"><%= r.label %></span><span class="font-semibold tabular-nums"><%= r.value.toLocaleString() %></span></div>
          <div class="bar-track"><div class="bar-fill" style="width:<%= r.w %>%;background:#eb6834"></div></div>
        </li>
      <% }) %>
      </ul>
    </div>

    <!-- Audience -->
    <div class="bg-white border border-zinc-200 rounded-xl p-5">
      <h2 class="font-display font-bold mb-4">Audience</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
        <% [['Device', data.devices],['Browser', data.browsers],['OS', data.os]].forEach(function(grp){ %>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500 mb-2"><%= grp[0] %></p>
          <ul class="space-y-1">
          <% (grp[1]||[]).slice(0,5).forEach(function(r){ %>
            <li class="flex justify-between"><span class="truncate mr-2 text-zinc-700"><%= r.label %></span><span class="text-zinc-500 tabular-nums"><%= r.pageviews %></span></li>
          <% }) %>
          <% if(!(grp[1]||[]).length){ %><li class="text-zinc-400">—</li><% } %>
          </ul>
        </div>
        <% }) %>
      </div>
      <% if ((data.countries||[]).length) { %>
      <div class="mt-4 pt-4 border-t border-zinc-100">
        <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500 mb-2">Top countries</p>
        <div class="flex flex-wrap gap-2">
        <% data.countries.slice(0,8).forEach(function(r){ %>
          <span class="text-xs bg-surface-2 border border-zinc-200 rounded-full px-2.5 py-1"><%= r.label %> · <%= r.pageviews %></span>
        <% }) %>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('partials/foot') %>
