<%- include('partials/head') %>
<div data-editor-root>
  <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
    <div>
      <a href="/admin/articles" class="text-sm text-zinc-500 hover:text-primary-dark inline-flex items-center gap-1"><span class="material-symbols-outlined text-base">arrow_back</span>Articles</a>
      <h1 class="font-display text-2xl sm:text-3xl font-bold mt-1"><%= article ? 'Edit article' : 'New article' %></h1>
    </div>
    <div class="flex items-center gap-2">
      <span data-status-pill class="text-xs font-bold uppercase px-2 py-1 rounded bg-zinc-100 text-zinc-600"><%= article ? article.status : 'unsaved' %></span>
      <button type="button" data-action="preview" class="inline-flex items-center gap-1.5 border border-zinc-300 bg-white hover:bg-surface-2 text-zinc-700 font-semibold text-sm px-3 py-2 rounded-lg"><span class="material-symbols-outlined text-base">visibility</span>Preview</button>
      <button type="button" data-action="save-draft" class="inline-flex items-center gap-1.5 border border-zinc-300 bg-white hover:bg-surface-2 text-zinc-800 font-semibold text-sm px-3 py-2 rounded-lg"><span class="material-symbols-outlined text-base">save</span>Save draft</button>
      <button type="button" data-action="publish" class="inline-flex items-center gap-1.5 bg-primary hover:bg-orange-600 text-white font-display font-bold uppercase text-sm tracking-tight px-4 py-2 rounded-lg"><span class="material-symbols-outlined text-base">publish</span>Publish</button>
    </div>
  </div>

  <div data-flash class="hidden mb-4 rounded-lg px-4 py-3 text-sm"></div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main column -->
    <div class="lg:col-span-2 space-y-5">
      <div class="bg-white border border-zinc-200 rounded-xl p-5">
        <label class="block text-xs font-semibold uppercase tracking-wide text-zinc-500 mb-1.5">Title</label>
        <input data-field="title" type="text" class="w-full text-lg font-display font-semibold rounded-lg border-zinc-300 focus:border-orange-500 focus:ring-orange-500" placeholder="Top 5 Hidden Coastal Drives in Bavaria"/>
        <div class="flex items-center gap-2 mt-3">
          <span class="text-xs text-zinc-500">Slug:</span>
          <input data-field="slug" type="text" class="flex-1 text-sm rounded-lg border-zinc-200 focus:border-orange-500 focus:ring-orange-500 font-mono" placeholder="auto-generated"/>
          <span class="text-xs text-zinc-400">.html</span>
        </div>
      </div>

      <!-- WYSIWYG editor -->
      <div class="bg-white border border-zinc-200 rounded-xl overflow-hidden">
        <div class="flex flex-wrap items-center gap-1 border-b border-zinc-200 px-3 py-2 bg-surface-2" data-toolbar>
          <button type="button" data-cmd="bold" class="ed-btn" title="Bold"><span class="material-symbols-outlined text-lg">format_bold</span></button>
          <button type="button" data-cmd="italic" class="ed-btn" title="Italic"><span class="material-symbols-outlined text-lg">format_italic</span></button>
          <span class="w-px h-5 bg-zinc-300 mx-1"></span>
          <button type="button" data-block="h2" class="ed-btn" title="Heading 2"><span class="text-sm font-bold">H2</span></button>
          <button type="button" data-block="h3" class="ed-btn" title="Heading 3"><span class="text-sm font-bold">H3</span></button>
          <button type="button" data-block="p" class="ed-btn" title="Paragraph"><span class="material-symbols-outlined text-lg">notes</span></button>
          <span class="w-px h-5 bg-zinc-300 mx-1"></span>
          <button type="button" data-cmd="insertUnorderedList" class="ed-btn" title="Bulleted list"><span class="material-symbols-outlined text-lg">format_list_bulleted</span></button>
          <button type="button" data-cmd="insertOrderedList" class="ed-btn" title="Numbered list"><span class="material-symbols-outlined text-lg">format_list_numbered</span></button>
          <button type="button" data-block="blockquote" class="ed-btn" title="Quote"><span class="material-symbols-outlined text-lg">format_quote</span></button>
          <span class="w-px h-5 bg-zinc-300 mx-1"></span>
          <button type="button" data-action="link" class="ed-btn" title="Insert link"><span class="material-symbols-outlined text-lg">link</span></button>
          <button type="button" data-action="image" class="ed-btn" title="Insert image"><span class="material-symbols-outlined text-lg">image</span></button>
        </div>
        <div data-editor contenteditable="true" class="prose max-w-none min-h-[360px] px-5 py-4 focus:outline-none text-[16px] leading-relaxed"></div>
      </div>
      <p class="text-xs text-zinc-400">Read time is estimated automatically (<span data-readtime>—</span> min). Override in the sidebar if needed.</p>
    </div>

    <!-- Sidebar -->
    <div class="space-y-5">
      <div class="bg-white border border-zinc-200 rounded-xl p-5 space-y-4">
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wide text-zinc-500 mb-1.5">Category</label>
          <input data-field="category" type="text" list="cats" class="w-full text-sm rounded-lg border-zinc-300 focus:border-orange-500 focus:ring-orange-500" placeholder="Coastal Drives"/>
          <datalist id="cats">
            <option>Coastal Drives</option><option>Day Trips</option><option>Alpine Transfers</option>
            <option>Group Travel</option><option>Sustainable Mobility</option><option>Field Notes</option>
          </datalist>
        </div>
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wide text-zinc-500 mb-1.5">Author</label>
          <input data-field="author_name" type="text" class="w-full text-sm rounded-lg border-zinc-300 focus:border-orange-500 focus:ring-orange-500" placeholder="Daniel (Klaxo Team)"/>
        </div>
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wide text-zinc-500 mb-1.5">Excerpt</label>
          <textarea data-field="excerpt" rows="3" class="w-full text-sm rounded-lg border-zinc-300 focus:border-orange-500 focus:ring-orange-500" placeholder="One or two sentence summary."></textarea>
        </div>
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wide text-zinc-500 mb-1.5">Read time (min)</label>
          <input data-field="read_time_minutes" type="number" min="1" max="120" class="w-28 text-sm rounded-lg border-zinc-300 focus:border-orange-500 focus:ring-orange-500"/>
        </div>
      </div>

      <div class="bg-white border border-zinc-200 rounded-xl p-5 space-y-4">
        <p class="text-xs font-bold uppercase tracking-wide text-zinc-500">Hero image</p>
        <div data-hero-preview class="hidden aspect-video rounded-lg bg-surface-2 overflow-hidden border border-zinc-200">
          <img data-hero-img class="w-full h-full object-cover" alt=""/>
        </div>
        <input data-field="hero_image_url" type="url" class="w-full text-sm rounded-lg border-zinc-300 focus:border-orange-500 focus:ring-orange-500" placeholder="https://…"/>
        <input data-field="hero_image_alt" type="text" class="w-full text-sm rounded-lg border-zinc-300 focus:border-orange-500 focus:ring-orange-500" placeholder="Descriptive alt text"/>
        <label class="inline-flex items-center gap-2 text-sm text-primary-dark font-semibold cursor-pointer">
          <span class="material-symbols-outlined text-base">upload</span> Upload image
          <input type="file" accept="image/*" class="hidden" data-hero-upload/>
        </label>
      </div>

      <details class="bg-white border border-zinc-200 rounded-xl p-5">
        <summary class="text-xs font-bold uppercase tracking-wide text-zinc-500 cursor-pointer">SEO</summary>
        <div class="space-y-3 mt-3">
          <input data-field="seo_title" type="text" class="w-full text-sm rounded-lg border-zinc-300 focus:border-orange-500 focus:ring-orange-500" placeholder="SEO title (defaults to title)"/>
          <textarea data-field="seo_description" rows="2" class="w-full text-sm rounded-lg border-zinc-300 focus:border-orange-500 focus:ring-orange-500" placeholder="Meta description (defaults to excerpt)"></textarea>
        </div>
      </details>
    </div>
  </div>
</div>

<style>
  .ed-btn { display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:8px; color:#3f3f46; }
  .ed-btn:hover { background:#fff; }
  [data-editor] h2 { font-family:'Space Grotesk',sans-serif; font-size:1.6rem; font-weight:700; margin:1.2rem 0 .6rem; }
  [data-editor] h3 { font-family:'Space Grotesk',sans-serif; font-size:1.25rem; font-weight:600; margin:1rem 0 .5rem; }
  [data-editor] p { margin:0 0 1rem; }
  [data-editor] ul { list-style:disc; padding-left:1.4rem; margin:0 0 1rem; }
  [data-editor] ol { list-style:decimal; padding-left:1.4rem; margin:0 0 1rem; }
  [data-editor] blockquote { border-left:4px solid #ff8c00; padding-left:1rem; color:#564334; margin:0 0 1rem; }
  [data-editor] img { max-width:100%; border-radius:.5rem; margin:.5rem 0; }
  [data-editor] a { color:#904d00; text-decoration:underline; }
  [data-editor]:empty:before { content:'Write your article…'; color:#a1a1aa; }
</style>

<script id="article-data" type="application/json"><%- article ? JSON.stringify(article) : 'null' %></script>
<%- include('partials/foot') %>
