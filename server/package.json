{
  "name": "klaxo-blog-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Admin dashboard + backend for the Klaxo Travel Tips blog: analytics, no-code publishing, and secure admin login. Publishes static HTML to the GitHub Pages repo via the GitHub API.",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node-pg-migrate -j js -m migrations up",
    "migrate:down": "node-pg-migrate -j js -m migrations down",
    "create-admin": "node bin/create-admin.js",
    "seed:articles": "node bin/seed-articles.js",
    "test": "node --test"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^9.0.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "multer": "^2.0.1",
    "pg": "^8.12.0",
    "sanitize-html": "^2.13.0",
    "ua-parser-js": "^1.0.38"
  },
  "devDependencies": {
    "node-pg-migrate": "^7.6.1"
  }
}
