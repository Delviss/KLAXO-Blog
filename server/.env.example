# ---------------------------------------------------------------------------
# Klaxo Blog backend — environment variables
# Copy to `.env` for local dev. On Railway, set these as service variables.
# NOTHING in here is committed; keep real secrets out of the repo.
# ---------------------------------------------------------------------------

# Core
NODE_ENV=development
PORT=3000
# Public URL of this backend (used for cookies, CORS logging, absolute links)
APP_URL=http://localhost:3000

# Postgres — Railway injects DATABASE_URL automatically for the Postgres plugin.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/klaxo_blog
# Set to "true" when your Postgres requires SSL (most managed providers do).
DATABASE_SSL=false

# Session — generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Analytics visitor-hash salt — a second long random secret, rotated daily in code.
ANALYTICS_SALT=change-me-to-another-long-random-string

# ---------------------------------------------------------------------------
# GitHub auto-publish (issue #18)
# A least-privilege token/App with contents:write on the blog repo ONLY.
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_xxx_least_privilege_contents_write_only
GITHUB_OWNER=Delviss
GITHUB_REPO=KLAXO-Blog
GITHUB_BRANCH=main
# Public base URL of the deployed static site (for sitemap.xml / canonical URLs).
SITE_BASE_URL=https://blog.klaxo.eu

# ---------------------------------------------------------------------------
# First admin bootstrap (used by `npm run create-admin` when flags are omitted)
# ---------------------------------------------------------------------------
ADMIN_EMAIL=media@klaxo.eu
# Do NOT hardcode a password here in production — the CLI will prompt instead.
# ADMIN_PASSWORD=

# CORS — comma-separated list of origins allowed to POST to /api/collect.
ALLOWED_ORIGINS=https://blog.klaxo.eu,https://delviss.github.io,http://localhost:8080
