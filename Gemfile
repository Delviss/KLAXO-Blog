source "https://rubygems.org"

# Build the site with Jekyll 4. This is what the GitHub Actions workflow uses
# to turn CMS-authored Markdown posts into styled HTML pages.
gem "jekyll", "~> 4.4"

# Windows/JRuby time zone data (harmless elsewhere).
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
